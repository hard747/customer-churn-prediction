    csv -.->|"simula"| crm
    crm --> extract
    extract --> r1 & r2 & r3 & r4

    r1 & r2 & r3 & r4 --> dbtrun
    dbtrun --> dbttest
    dbttest -->|"PASS"| feat
    dbttest -->|"FAIL"| stop["Flow se detiene<br/><small>no entrena con datos malos</small>"]

    feat --> train
    train --> model
    model --> score
    feat --> score
    score --> scores
    scores --> bi

    style crm fill:#8a8a8a,color:#fff
    style csv fill:#5f5fa8,color:#fff
    style feat fill:#1a5fb4,color:#fff
    style dbttest fill:#c64600,color:#fff
    style stop fill:#a51d2d,color:#fff
    style model fill:#26a269,color:#fff
    style bi fill:#8a8a8a,color:#fff
