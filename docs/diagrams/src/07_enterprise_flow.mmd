flowchart TB
    csv[("Telco-Customer-Churn.csv<br/><small>unica fuente real</small>")]

    subgraph sim["Simulado (no existe de verdad)"]
        crm["CRM / ERP<br/><small>Salesforce / SAP</small>"]
    end

    extract["extract_to_raw()<br/><small>build_raw_tables.py</small>"]

    subgraph raw["Capa RAW (Postgres)"]
        direction LR
        r1[("raw_crm_customers")]
        r2[("raw_crm_subscriptions")]
        r3[("raw_billing_charges")]
        r4[("raw_churn_labels")]
    end

    dbtrun["dbt run<br/><small>staging + mart</small>"]
    dbttest{"dbt test<br/><small>25 tests</small>"}
    feat[("fct_customer_features<br/><small>feature table</small>")]

    train["train_from_feature_table.py<br/><small>LR / RF / XGBoost + CV</small>"]
    model[("best_model.joblib")]
    score["generate_risk_scores_from_feature_table.py"]
