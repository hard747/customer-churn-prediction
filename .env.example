# Copiar este arquivo para ".env" (que ja esta no .gitignore, nunca e
# commitado) para usar Postgres em vez de SQLite. O .env e carregado
# automaticamente (python-dotenv, ver src/db.py) -- nao precisa
# exportar nada manualmente.
#
# Uso (pipeline simples, SQLite/Postgres):
#   1. cp .env.example .env
#   2. docker compose up -d
#   3. python src/run_all.py
#
# Se DATABASE_URL nao estiver definida, o projeto usa SQLite
# automaticamente (ver src/db.py) — Postgres e opcional, nao um
# requisito para reproduzir o projeto.

POSTGRES_DB=churn
POSTGRES_USER=churn_user
POSTGRES_PASSWORD=churn_password
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg2://churn_user:churn_password@localhost:5432/churn

# --- So para warehouse_demo/ (padrao enterprise: CRM -> Prefect -> ---
# --- Postgres -> dbt -> feature table -> modelo). Mesmas credenciais ---
# --- de cima, mas o dbt precisa dos campos separados em vez de uma ---
# --- unica URL. Ver warehouse_demo/README.md. ---
PGHOST=localhost
PGPORT=5432
PGUSER=churn_user
PGPASSWORD=churn_password
PGDATABASE=churn
PGSSLMODE=prefer
